* text=auto

# Source code and markup: keep normalized LF in the working tree.
*.cs        text eol=lf
*.csx       text eol=lf
*.vb        text eol=lf
*.axaml     text eol=lf
*.xaml      text eol=lf
*.xml       text eol=lf
*.resx      text eol=lf
*.json      text eol=lf
*.jsonl     text eol=lf
*.md        text eol=lf
*.toml      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.txt       text eol=lf
*.svg       text eol=lf
*.targets   text eol=lf
*.props     text eol=lf
*.csproj    text eol=lf
*.fsproj    text eol=lf
*.vbproj    text eol=lf
*.sh        text eol=lf
*.py        text eol=lf

# Windows-native files are more comfortable with CRLF locally.
*.sln       text eol=crlf
*.slnx      text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf
*.psm1      text eol=crlf

# Binary assets and build outputs must never be normalized.
*.png       -text
*.jpg       -text
*.jpeg      -text
*.gif       -text
*.ico       -text
*.pdf       -text
*.zip       -text
*.nupkg     -text
*.dll       -text
*.exe       -text
*.pdb       -text
*.so        -text
*.dylib     -text
